      "category": "learning",
      "role": "Minimal CLI and Python workflows for outputs, plots, and geometry setup.",
      "start_here": "getting_started/write_sfincs_output_python.py"
    },
    "optimization": {
      "category": "capability",
      "role": "Optimization objectives, candidate screening, and kinetic-promotion helpers.",
      "start_here": "optimization/qa_nfp2_sfincs_jax_objectives.py"
    },
    "parity": {
      "category": "validation",
      "role": "Frozen-reference parity checks against SFINCS Fortran v3 artifacts.",
      "start_here": "parity/output_parity_vs_fortran_fixture.py"
    },
    "performance": {
      "category": "validation",
      "role": "JIT, memory, output-format, CPU/GPU, and parallel scaling benchmarks.",
      "start_here": "performance/benchmark_output_formats.py"
    },
    "publication_figures": {
      "category": "validation",
      "role": "Documentation and paper-figure regeneration from checked summaries or explicit runs.",
      "start_here": "publication_figures/generate_fortran_suite_benchmark_summary.py"
    },
    "sfincs_examples": {
      "category": "reference",
      "role": "Vendored upstream SFINCS v3 examples for parity and benchmark audits.",
