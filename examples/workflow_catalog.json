      "command": "python examples/publication_figures/generate_fortran_suite_benchmark_summary.py --min-fortran-runtime-s 10",
      "topic": "publication_figures",
      "keywords": ["runtime", "memory", "fortran", "benchmark", "figure", "parity"],
      "runtime_budget": "seconds from checked reports",
      "requires_fortran_v3": false
    }
  ]
}
