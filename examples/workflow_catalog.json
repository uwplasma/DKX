    {
      "id": "output_format_benchmark",
      "goal": "Time output formats and memory behavior.",
      "entrypoint": "performance/benchmark_output_formats.py",
      "command": "python examples/performance/benchmark_output_formats.py --repeats 2",
      "topic": "performance",
      "keywords": ["performance", "runtime", "memory", "io", "gpu", "cpu", "output"],
      "runtime_budget": "seconds",
      "requires_fortran_v3": false
    },
    {
      "id": "frozen_fortran_fixture",
      "goal": "Check a frozen Fortran-v3 output fixture.",
