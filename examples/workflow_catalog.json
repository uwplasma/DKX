{
  "schema_version": 1,
  "purpose": "Machine-readable navigation map for public sfincs_jax examples.",
  "folders": {
    "autodiff": {
      "category": "capability",
      "role": "JAX gradients, JVP/VJP examples, and implicit differentiation.",
      "start_here": "autodiff/autodiff_gradient_nu_n_residual.py"
    },
    "data": {
      "category": "reference",
      "role": "Small shared input files used by public examples.",
      "start_here": "data/geometryScheme4_quick_2species.input.namelist"
    },
