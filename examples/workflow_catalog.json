      "topic": "getting_started",
      "keywords": ["cli", "plot", "hdf5", "netcdf", "npz", "diagnostics"],
      "runtime_budget": "seconds",
      "requires_fortran_v3": false
    },
    {
      "id": "multi_format_output",
      "goal": "Inspect HDF5, NetCDF, NPZ, and plotting.",
