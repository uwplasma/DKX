    },
    "tutorials": {
      "category": "learning",
      "role": "Notebook-led learning path and fast tutorial output writer.",
      "start_here": "tutorials/00_start_here.ipynb"
    },
    "vmec_jax_finite_beta": {
      "category": "capability",
      "role": "Finite-beta VMEC, ambipolar electric field, Redl, and bootstrap-current workflows.",
