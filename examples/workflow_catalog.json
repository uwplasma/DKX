      "topic": "validation",
      "keywords": ["parity", "validation", "fortran", "fixture", "hdf5"],
      "runtime_budget": "seconds",
      "requires_fortran_v3": false
    },
    {
      "id": "qa_optimization_objective",
      "goal": "Add neoclassical objectives to QA/QI optimization.",
      "entrypoint": "optimization/qa_nfp2_sfincs_jax_objectives.py",
      "command": "python examples/optimization/qa_nfp2_sfincs_jax_objectives.py --help",
      "topic": "optimization",
      "keywords": ["optimization", "qa", "qi", "bootstrap", "objectives"],
      "runtime_budget": "seconds for proxy setup; kinetic promotion is explicit",
      "requires_fortran_v3": false
    },
    {
      "id": "vmec_boozer_jax_pipeline",
      "goal": "Inspect the VMEC-JAX to Boozer/SFINCS-JAX differentiable workflow.",
      "entrypoint": "autodiff/vmec_jax_to_boozer_sfincs_pipeline.py",
      "command": "python examples/autodiff/vmec_jax_to_boozer_sfincs_pipeline.py --help",
      "topic": "autodiff_geometry",
      "keywords": ["vmec_jax", "booz_xform_jax", "boozer", "autodiff", "geometry"],
      "runtime_budget": "optional dependency workflow",
