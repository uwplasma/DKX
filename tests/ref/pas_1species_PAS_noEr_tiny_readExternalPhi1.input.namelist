! Tiny PAS example that reads a FIXED external Phi1(theta,zeta) field (readExternalPhi1=.true.),
! designed for parity testing in sfincs_jax.
!
! readExternalPhi1 makes the drift-kinetic equation LINEAR again: Phi1 is read from
! externalPhi1Filename and held fixed (NO quasineutrality block, NO Phi1 unknown, NO lambda row).
! The external field is the sfincsOutput.h5 from the sibling self-consistent
! pas_1species_PAS_noEr_tiny_withPhi1_inKinetic_linear deck (same grid, so no interpolation).

&general
  saveMatricesAndVectorsInBinary = .t.
/

&geometryParameters
  geometryScheme = 4
/

&speciesParameters
  Zs = 1
  mHats = 1.0d+0
  nHats = 1.0d+0
  THats = 1.0d+0

  dNHatdrHats = -0.5d+0
  dTHatdrHats = -2.0d+0

  ! Provide gradients directly in psiHat to avoid ambiguity about radial coordinate conversions:
  dNHatdpsiHats = -0.3d+0
  dTHatdpsiHats = -0.2d+0

  withAdiabatic = .t.
  adiabaticZ = -1
  adiabaticNHat = 1.0d+0
  adiabaticTHat = 1.0d+0
/

&physicsParameters
  Delta = 4.5694d-3
  alpha = 1.0d+0
  nu_n = 8.4774d-3
  Er = 0.0d+0

  collisionOperator = 1
  includeXDotTerm = .false.
  includeElectricFieldTermInXiDot = .false.
  useDKESExBDrift = .false.

  includePhi1 = .true.
  includePhi1InKineticEquation = .true.
  includePhi1InCollisionOperator = .false.
  quasineutralityOption = 2

  readExternalPhi1 = .true.
  externalPhi1Filename = "externalPhi1.h5"
/

&resolutionParameters
  Ntheta = 5
  Nzeta = 5
  Nxi = 4
  NL = 2
  Nx = 3
  solverTolerance = 1d-10
/

&otherNumericalParameters
  Nxi_for_x_option = 0
/

&preconditionerOptions
/

&export_f
  export_full_f = .false.
  export_delta_f = .false.
/
